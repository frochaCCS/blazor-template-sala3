@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@layout AuthenticatedLayout

@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject UserManager<ApplicationUser> UserManager
@inject ITicketService TicketService

<PageTitle>Admin</PageTitle>

<h1>Admin Panel</h1>

<div class="stats-grid" style="margin-bottom: 1.5rem;">
    <div class="stat-card">
        <div class="stat-number">@totalTickets</div>
        <div class="stat-label">Total Tickets</div>
    </div>
    <div class="stat-card stat-open">
        <div class="stat-number">@unassignedCount</div>
        <div class="stat-label">Unassigned</div>
    </div>
    <div class="stat-card" style="background-color: var(--destructive); color: var(--destructive-foreground);">
        <div class="stat-number">@criticalCount</div>
        <div class="stat-label">Critical</div>
    </div>
    <div class="stat-card" style="background-color: var(--primary); color: var(--primary-foreground);">
        <div class="stat-number">@highCount</div>
        <div class="stat-label">High Priority</div>
    </div>
</div>

<div class="card" style="margin-bottom: 1.5rem;">
    <h2>User Management</h2>
    <table class="data-table">
        <thead>
            <tr>
                <th>Email</th>
                <th>Display Name</th>
                <th>Roles</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var userInfo in users)
            {
                <tr>
                    <td>@userInfo.Email</td>
                    <td>@userInfo.DisplayName</td>
                    <td>
                        @foreach (var r in userInfo.Roles)
                        {
                            <span class="badge">@r</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<UserInfo> users = new();
    private int totalTickets, unassignedCount, criticalCount, highCount;

    protected override async Task OnInitializedAsync()
    {
        var allUsers = await UserManager.Users.ToListAsync();
        foreach (var user in allUsers)
        {
            var roles = await UserManager.GetRolesAsync(user);
            users.Add(new UserInfo
            {
                Email = user.Email ?? "",
                DisplayName = user.DisplayName ?? "",
                Roles = roles.ToList()
            });
        }

        var tickets = await TicketService.GetAllTicketsAsync();
        totalTickets = tickets.Count;
        unassignedCount = tickets.Count(t => t.AssignedToId is null);
        criticalCount = tickets.Count(t => t.Priority == TicketPriority.Critical);
        highCount = tickets.Count(t => t.Priority == TicketPriority.High);
    }

    private sealed class UserInfo
    {
        public string Email { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public List<string> Roles { get; set; } = new();
    }
}
